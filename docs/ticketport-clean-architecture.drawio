<mxfile host="app.diagrams.net" modified="2026-03-28T00:00:00.000Z" agent="TicketPort" version="22.1.0" type="device">
  <diagram id="clean-arch" name="Clean Architecture + Spring">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="TicketPort — Modular Monolith (Clean / Hexagonal + Spring)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="760" height="36" as="geometry"/>
        </mxCell>

        <mxCell id="rule" value="Bağımlılık kuralı: dış katmanlar içe doğru; Domain frameworksüz (Spring yok)." style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="200" y="58" width="760" height="28" as="geometry"/>
        </mxCell>

        <!-- Domain center -->
        <mxCell id="domain-box" value="&lt;b&gt;Domain&lt;/b&gt; (*-domain)&lt;br&gt;Aggregate, Entity, VO, domain exception&lt;br&gt;&lt;i&gt;Pure Java — @Component / @Service yok&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=middle;align=center;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="420" y="280" width="320" height="100" as="geometry"/>
        </mxCell>

        <!-- Application -->
        <mxCell id="app-box" value="&lt;b&gt;Application&lt;/b&gt; (*-application)&lt;br&gt;• &lt;i&gt;port.in&lt;/i&gt; UseCase / Query arayüzleri&lt;br&gt;• &lt;i&gt;port.out&lt;/i&gt; persistence &amp; anti-corruption portları&lt;br&gt;• &lt;b&gt;@Service&lt;/b&gt; implementation’lar (use case / query)&lt;br&gt;• &lt;b&gt;Logging* + @Primary&lt;/b&gt;: decorator, runtime’da asıl use case yerine enjekte" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="360" height="130" as="geometry"/>
        </mxCell>

        <!-- API -->
        <mxCell id="api-box" value="&lt;b&gt;Driving adapters — API&lt;/b&gt; (*-api)&lt;br&gt;REST Controllers, DTO, security config&lt;br&gt;Use case arayüzlerini çağırır (constructor inject)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=middle;align=left;spacingLeft=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="300" height="90" as="geometry"/>
        </mxCell>

        <!-- Infra -->
        <mxCell id="infra-box" value="&lt;b&gt;Driven adapters — Infrastructure&lt;/b&gt; (*-infra)&lt;br&gt;JPA Entity, Repository&lt;br&gt;&lt;b&gt;@Component&lt;/b&gt; *JpaAdapter → port.out uygular&lt;br&gt;Mapper: Entity ↔ Domain" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;verticalAlign=top;align=left;spacingLeft=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="720" y="120" width="360" height="130" as="geometry"/>
        </mxCell>

        <!-- Bootstrap -->
        <mxCell id="boot-box" value="&lt;b&gt;Bootstrap&lt;/b&gt;&lt;br&gt;@SpringBootApplication — &lt;i&gt;com.furkan.ticketport&lt;/i&gt; component scan&lt;br&gt;Flyway, JPA, PostgreSQL&lt;br&gt;Modülleri classpath’te birleştirir (composition root)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=middle;align=left;spacingLeft=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="1000" height="90" as="geometry"/>
        </mxCell>

        <!-- Spring IoC note -->
        <mxCell id="spring-box" value="&lt;b&gt;Spring bean yönetimi (özet)&lt;/b&gt;&lt;br&gt;• Arayüz → tek &lt;b&gt;@Component/@Service&lt;/b&gt; aday: otomatik wiring (ör. SessionJpaAdapter → SessionPersistencePort)&lt;br&gt;• Aynı arayüzde &lt;b&gt;@Primary&lt;/b&gt; decorator delegate’i gölgede bırakır (LoggingCreateSessionUseCase → CreateSessionService)&lt;br&gt;• Unit test: *-application/test InMemory — Spring bean değil, manuel new&lt;br&gt;• Modüller: user-*, event-*, booking-domain, common/security" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;align=left;spacingLeft=8;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="1000" height="110" as="geometry"/>
        </mxCell>

        <!-- Arrows dependency -->
        <mxCell id="e1" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#333333;dashed=1" edge="1" parent="1" source="app-box" target="domain-box">
